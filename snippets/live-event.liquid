{%- assign is_br = false -%}
{%- if localization.country.iso_code == 'BR' or request.locale.iso_code contains 'pt' -%}
  {%- assign is_br = true -%}
{%- endif -%}

{%- assign title_pt = section.settings.title_pt -%}
{%- assign title_en = section.settings.title_en -%}
{%- assign desc_pt  = section.settings.desc_pt -%}
{%- assign desc_en  = section.settings.desc_en -%}
{%- assign date_pt  = section.settings.date_pt -%}
{%- assign date_en  = section.settings.date_en -%}

{%- comment -%} TODO: adicionar suporte a espanhol futuramente {%- endcomment -%}

{%- if is_br -%}
  {%- assign ui_kicker      = 'PRÓXIMA LIVE' -%}
  {%- assign ui_cta_btn     = 'Receber lembrete' -%}
  {%- assign ui_placeholder = 'Seu e-mail' -%}
  {%- assign ui_hint        = 'Avisaremos por e-mail quando a live começar.' -%}
  {%- assign ui_sending     = 'Enviando…' -%}
  {%- assign ui_success     = 'Pronto! Enviaremos o lembrete por e-mail.' -%}
  {%- assign ui_error       = 'Confira seu e-mail e tente novamente.' -%}
  {%- assign v_title        = title_pt -%}
  {%- assign v_desc         = desc_pt -%}
  {%- assign v_date         = date_pt -%}
  {%- assign v_date_label   = 'Data e horário' -%}
{%- else -%}
  {%- assign ui_kicker      = 'NEXT LIVE' -%}
  {%- assign ui_cta_btn     = 'Email Reminder' -%}
  {%- assign ui_placeholder = 'Your email' -%}
  {%- assign ui_hint        = 'We'll email you when the live starts.' -%}
  {%- assign ui_sending     = 'Sending…' -%}
  {%- assign ui_success     = 'Done! We'll send your reminder.' -%}
  {%- assign ui_error       = 'Please check your email and try again.' -%}
  {%- assign v_title        = title_en -%}
  {%- assign v_desc         = desc_en -%}
  {%- assign v_date         = date_en -%}
  {%- assign v_date_label   = 'Date and time' -%}
{%- endif -%}

<style>
  .rx-wrap {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem;
    align-items: start;
  }

  .rx-16x9 {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 6px;
    background: #000;
  }

  .rx-16x9 iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: 0;
  }

  .rx-right {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .rx-logos {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .rx-logos img { display: block; }

  .rx-divider {
    color: #ccc;
    font-size: 1.2rem;
    line-height: 1;
  }

  .rx-kicker {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #999;
    font-weight: 600;
  }

  .rx-title {
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.25;
    color: #1a1a1a;
    margin: 0;
  }

  .rx-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #555;
  }

  .rx-date {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #444;
    margin-bottom: 0.6rem;
  }

  .rx-date svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: #888;
  }

  .rx-news-form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .rx-input {
    flex: 1;
    padding: 0.65rem 0.9rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .rx-input:focus { border-color: #888; }

  .rx-btn {
    padding: 0.65rem 1.1rem;
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .rx-btn:hover { opacity: 0.8; }
  .rx-btn:disabled { opacity: 0.5; cursor: default; }

  .rx-hint {
    font-size: 0.75rem;
    color: #999;
  }

  .rx-alert {
    font-size: 0.82rem;
    padding: 0.6rem 0.9rem;
    border-radius: 4px;
    margin-top: 0.5rem;
    transition: opacity 0.45s;
  }

  .rx-alert.is-hidden { opacity: 0; }
  .rx-success { background: #e6f4ea; color: #2d6a3f; }
  .rx-error   { background: #fdecea; color: #a33; }

  @media (max-width: 768px) {
    .rx-wrap {
      grid-template-columns: 1fr;
      padding: 1.25rem;
    }
  }
</style>

<div class="rx-wrap">
  <div class="rx-embed">
    <div class="rx-16x9">
      <iframe
        src="https://vimeo.com/event/{{ section.settings.vimeo_event_id }}/embed/{{ section.settings.vimeo_hash }}/interaction"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture; encrypted-media; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen>
      </iframe>
    </div>
  </div>

  <aside class="rx-right">
    {% if section.settings.instagram_handle != blank or section.settings.brand_logo != blank %}
      <div class="rx-logos">
        {% if section.settings.instagram_handle != blank %}
          <a href="https://instagram.com/{{ section.settings.instagram_handle }}" target="_blank" rel="noopener">
            <img src="{{ section.settings.instagram_logo | image_url: height: 30 }}" alt="Instagram" height="30" loading="lazy" decoding="async">
          </a>
        {% endif %}
        {% if section.settings.brand_logo != blank %}
          <span class="rx-divider">|</span>
          <a href="{{ section.settings.brand_url }}" target="_blank" rel="noopener">
            <img src="{{ section.settings.brand_logo | image_url: height: 30 }}" alt="{{ section.settings.brand_name }}" height="30" loading="lazy" decoding="async">
          </a>
        {% endif %}
      </div>
    {% endif %}

    <div class="rx-kicker">{{ ui_kicker }}</div>
    <h2 class="rx-title">{{ v_title }}</h2>
    <p class="rx-desc">{{ v_desc }}</p>

    <div class="rx-date" aria-label="{{ v_date_label }}">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M7 2v3M17 2v3M3 9h18M5 7h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2Z"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>{{ v_date }}</span>
    </div>

    <div class="rx-news-wrap">
      {% form 'customer', id: 'rx-newsletter', novalidate: 'novalidate' %}
        <input type="hidden" name="contact[tags]" value="newsletter, live-reminder">
        <div class="rx-news-form">
          <input
            class="rx-input"
            type="email"
            name="contact[email]"
            placeholder="{{ ui_placeholder }}"
            required
            aria-label="{{ ui_placeholder }}"
            autocomplete="email"
            inputmode="email"
          >
          <button class="rx-btn" type="submit" id="rx-submit">{{ ui_cta_btn }}</button>
        </div>

        {% if form.posted_successfully? %}
          <div class="rx-alert rx-success rx-alert--form" role="status" aria-live="polite">{{ ui_success }}</div>
        {% endif %}

        {% if form.errors %}
          <div class="rx-alert rx-error rx-alert--form" role="status" aria-live="polite">{{ ui_error }}</div>
        {% endif %}
      {% endform %}

      <div class="rx-hint">{{ ui_hint }}</div>
    </div>
  </aside>
</div>

<script>
(function() {
  const form = document.getElementById('rx-newsletter');
  const btn  = document.getElementById('rx-submit');

  if (form && btn) {
    form.addEventListener('submit', function() {
      btn.dataset.original = btn.textContent;
      btn.textContent = {{ ui_sending | json }};
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
    }, { passive: true });
  }

  // esconde o alerta depois de 7s ou ao clicar
  const alertEl = document.querySelector('.rx-alert--form');
  if (alertEl) {
    const hide = function() {
      alertEl.classList.add('is-hidden');
      setTimeout(function() {
        if (alertEl.parentNode) alertEl.parentNode.removeChild(alertEl);
      }, 450);
    };

    const timer = setTimeout(hide, 7000);
    alertEl.addEventListener('click', function() {
      clearTimeout(timer);
      hide();
    });
  }
})();
</script>

{% schema %}
{
  "name": "Evento ao Vivo",
  "settings": [
    {
      "type": "text",
      "id": "vimeo_event_id",
      "label": "ID do evento Vimeo",
      "default": "EXAMPLE_ID"
    },
    {
      "type": "text",
      "id": "vimeo_hash",
      "label": "Hash do embed Vimeo",
      "default": "EXAMPLE_HASH"
    },
    {
      "type": "text",
      "id": "title_pt",
      "label": "Título (PT)",
      "default": "Título do evento"
    },
    {
      "type": "textarea",
      "id": "desc_pt",
      "label": "Descrição (PT)"
    },
    {
      "type": "text",
      "id": "date_pt",
      "label": "Data e horário (PT)",
      "default": "15 de janeiro • 19h (horário de Brasília)"
    },
    {
      "type": "text",
      "id": "title_en",
      "label": "Title (EN)",
      "default": "Event title"
    },
    {
      "type": "textarea",
      "id": "desc_en",
      "label": "Description (EN)"
    },
    {
      "type": "text",
      "id": "date_en",
      "label": "Date and time (EN)",
      "default": "January 15 • 7pm (Brasília time)"
    },
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "Handle do Instagram"
    },
    {
      "type": "image_picker",
      "id": "instagram_logo",
      "label": "Logo do Instagram"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Logo da marca"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Nome da marca"
    },
    {
      "type": "url",
      "id": "brand_url",
      "label": "Link da marca"
    }
  ],
  "presets": [
    { "name": "Evento ao Vivo" }
  ]
}
{% endschema %}
