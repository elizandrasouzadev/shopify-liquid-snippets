{% assign promo_end_date = section.settings.promo_end_date | default: '2026-12-31T23:59:59Z' %}

<div class="promo-countdown">
  <strong>🔥 {{ section.settings.promo_label | default: 'Oferta por tempo limitado!' }}</strong>
  <span id="countdown-timer" class="countdown-timer"></span>
</div>

<style>
  .promo-countdown {
    background: #ffeaa7;
    padding: 12px 16px;
    text-align: center;
    font-family: var(--font-body--family, Arial, sans-serif);
    font-size: 0.9rem;
  }

  .countdown-timer {
    margin-left: 8px;
    font-weight: 600;
    letter-spacing: 0.03em;
  }
</style>

<script>
  (function() {
    const timerEl = document.getElementById('countdown-timer');
    const endTime = new Date('{{ promo_end_date }}').getTime();

    // unidades em ms para deixar a conta mais legível
    const MINUTE = 1000 * 60;
    const HOUR   = MINUTE * 60;
    const DAY    = HOUR * 24;

    function tick() {
      const diff = endTime - Date.now();

      if (diff <= 0) {
        timerEl.textContent = 'Promoção encerrada';
        clearInterval(interval);
        return;
      }

      const days    = Math.floor(diff / DAY);
      const hours   = Math.floor((diff % DAY) / HOUR);
      const minutes = Math.floor((diff % HOUR) / MINUTE);
      const seconds = Math.floor((diff % MINUTE) / 1000);

      timerEl.textContent = days + 'd ' +
        String(hours).padStart(2, '0') + 'h ' +
        String(minutes).padStart(2, '0') + 'm ' +
        String(seconds).padStart(2, '0') + 's';
    }

    tick();
    const interval = setInterval(tick, 1000);
  })();
</script>

{% schema %}
{
  "name": "Contador de Promoção",
  "settings": [
    {
      "type": "text",
      "id": "promo_label",
      "label": "Texto da promoção",
      "default": "Oferta por tempo limitado!"
    },
    {
      "type": "text",
      "id": "promo_end_date",
      "label": "Data de encerramento (formato ISO)",
      "default": "2026-12-31T23:59:59Z"
    }
  ],
  "presets": [
    { "name": "Contador de Promoção" }
  ]
}
{% endschema %}
