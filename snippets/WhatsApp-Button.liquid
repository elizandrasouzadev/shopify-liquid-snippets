{%- assign wa_phone = section.settings.phone | default: '5511999999999' -%}
{%- assign wa_text  = section.settings.message | default: 'Olá, preciso de ajuda com meu pedido' | url_encode -%}

<div class="wa-btn-wrap">
  
    href="https://wa.me/{{ wa_phone }}?text={{ wa_text }}"
    class="wa-btn"
    aria-label="Falar pelo WhatsApp"
    target="_blank"
    rel="noopener"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
      <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.472-.149-.672.149-.198.297-.77.967-.944 1.164-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.787-1.48-1.757-1.653-2.054-.173-.297-.019-.458.13-.606.134-.133.297-.347.446-.52.149-.173.198-.297.297-.495.099-.198.05-.372-.025-.521-.074-.149-.672-1.623-.921-2.222-.242-.579-.487-.5-.672-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.876 1.213 3.074c.149.198 2.103 3.212 5.096 4.499.713.307 1.27.492 1.705.63.716.227 1.37.195 1.884.118.575-.086 1.758-.718 2.006-1.414.248-.695.248-1.29.173-1.414-.074-.124-.272-.198-.57-.347zM11.996 21.899h-.003a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982 1.0-3.648-.25-.374A9.86 9.86 0 0 1 1.05 11.5c0-5.45 4.44-9.89 9.895-9.89 2.64 0 5.122 1.03 6.993 2.9a9.82 9.82 0 0 1 2.9 6.99c-.003 5.44-4.443 9.88-9.887 9.88z"/>
    </svg>
  </a>
</div>

<style>
  .wa-btn-wrap {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
  }

  .wa-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: #25D366;
    color: #fff;
    border-radius: 50%;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.22);
    transition: transform 0.2s ease;
  }

  .wa-btn:hover {
    transform: scale(1.08);
  }

  .wa-btn svg { display: block; flex-shrink: 0; }
</style>

{% schema %}
{
  "name": "Botão WhatsApp",
  "settings": [
    {
      "type": "text",
      "id": "phone",
      "label": "Número do WhatsApp (com código do país)",
      "default": "5511999999999",
      "info": "Só números, sem espaços ou símbolos. Ex: 5511999999999"
    },
    {
      "type": "text",
      "id": "message",
      "label": "Mensagem pré-preenchida",
      "default": "Olá, preciso de ajuda com meu pedido"
    }
  ],
  "presets": [
    { "name": "Botão WhatsApp" }
  ]
}
{% endschema %}
